[Event/criticalbattery]
Execute=
Logfile=
TTS=

[Event/fullbattery]
Execute=
Logfile=
TTS=

[Event/lowbattery]
Execute=
Logfile=
Sound=/usr/share/sounds/Oxygen-Im-Connection-Lost.ogg
TTS=

[Event/lowperipheralbattery]
Execute=
Logfile=
TTS=

[Event/pluggedin]
Action=Sound
Execute=
Logfile=
TTS=

[Event/unplugged]
Execute=
Logfile=
Sound=/usr/share/sounds/Oxygen-Im-Cant-Connect.ogg
TTS=
